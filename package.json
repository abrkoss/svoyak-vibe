{
  "name": "svoyak-game",
  "version": "1.0.0",
  "description": "Local WiFi Svoyak (Jeopardy-style) game",
  "type": "module",
  "scripts": {
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite --config client/vite.config.js",
    "dev": "concurrently -k -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "build": "vite build --config client/vite.config.js",
    "start": "node server/index.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "qrcode": "^1.5.4",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "concurrently": "^8.2.2",
    "pinia": "^2.1.7",
    "socket.io-client": "^4.7.5",
    "vite": "^5.2.0",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  }
}
